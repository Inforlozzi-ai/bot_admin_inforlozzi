# --- NOVAS CONFIGURAÇÕES DE UPGRADE ---

# 1. Quantas mensagens a IA deve lembrar para entender o contexto (sugerido: 5)
MAX_CONTEXT_MESSAGES=5

# 2. Palavras que o bot deve ignorar (separe por vírgula e sem espaços)
IGNORE_KEYWORDS=bet,cassino,ganhe,promoção,filiado

# 3. Intervalo em segundos para a mensagem automática (ex: 3600 = 1 hora)
# Use 0 para desativar esta função
SCHEDULE_MSG_INTERVAL=3600

# 4. O texto que será enviado automaticamente no intervalo acima
SCHEDULE_MSG_TEXT=🚀 Gostou do conteúdo? Assine nosso VIP para sinais exclusivos!